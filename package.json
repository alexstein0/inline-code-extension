{
  "name": "inline-code",
  "displayName": "Inline Code",
  "description": "Inline code suggestions with structured edits (insert, delete, replace, move)",
  "version": "0.1.0",
  "publisher": "inline-code-research",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "inlineCode.acceptSuggestion",
        "title": "Inline Code: Accept Suggestion"
      },
      {
        "command": "inlineCode.dismissSuggestion",
        "title": "Inline Code: Dismiss Suggestion"
      },
      {
        "command": "inlineCode.triggerSuggestion",
        "title": "Inline Code: Trigger Suggestion"
      },
      {
        "command": "inlineCode.selectModel",
        "title": "Inline Code: Select Model"
      }
    ],
    "keybindings": [
      {
        "command": "inlineCode.acceptSuggestion",
        "key": "tab",
        "when": "inlineCode.suggestionVisible && editorTextFocus && !suggestWidgetVisible && !inSnippetMode"
      },
      {
        "command": "inlineCode.dismissSuggestion",
        "key": "escape",
        "when": "inlineCode.suggestionVisible && editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Inline Code",
      "properties": {
        "inlineCode.serverUrl": {
          "type": "string",
          "default": "http://localhost:8321",
          "description": "URL of the model server"
        },
        "inlineCode.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce delay in milliseconds before triggering prediction"
        },
        "inlineCode.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code suggestions"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
